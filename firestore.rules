rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ATENCAO: regras abertas — qualquer pessoa com a URL do projeto pode
    // ler e escrever. Adequado apenas enquanto o app nao tem autenticacao.
    // Antes de tornar o site publico, restrinja por auth (request.auth != null)
    // ou por um token compartilhado.
    match /vehicles/{docId} {
      allow read, write: if true;
    }
    match /expenses/{docId} {
      allow read, write: if true;
    }
    match /km_readings/{docId} {
      allow read, write: if true;
    }
  }
}
